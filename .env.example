# Caminho do repositório git onde o "git pull" será executado (obrigatório).
# Para servidores FiveM/RedM, aponte para a pasta "resources" do servidor: o
# serviço identifica quais resources mudaram para sugerir o restart.
PA_REPO_PATH=/srv/fivem/resources

# Remote e branch usados no pull. Branch vazio = usa o upstream da branch atual.
PA_REMOTE=origin
PA_BRANCH=main

# Modo de operação: "polling" ou "webhook".
PA_MODE=polling

# ---- Modo polling ----
# Intervalo entre pulls (formato de duração do Go: 30s, 5m, 1h...).
PA_POLL_INTERVAL=60s

# ---- Modo webhook ----
# Endereço e caminho onde o servidor escuta.
PA_LISTEN_ADDR=:8080
PA_WEBHOOK_PATH=/webhook
# Segredo compartilhado com o GitHub (obrigatório no modo webhook).
# Configure o MESMO valor no webhook do repositório no GitHub.
PA_WEBHOOK_SECRET=troque-por-um-segredo-forte

# ---- Serviço de log para o Discord (opcional) ----
# Se definido, os logs do serviço são espelhados para um canal do Discord.
# Crie em: Servidor > Configurações do canal > Integrações > Webhooks.
PA_DISCORD_WEBHOOK_URL=
# Nome exibido nas mensagens.
PA_DISCORD_USERNAME=pull-automator
# Nível mínimo encaminhado ao Discord: DEBUG, INFO, WARN ou ERROR.
# Em INFO: notifica mudanças aplicadas, erros e alertas de assinatura inválida,
# sem poluir com os pulls ociosos do modo polling.
PA_DISCORD_LEVEL=INFO
